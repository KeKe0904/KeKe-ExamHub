# 服务器配置
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# MySQL 数据库配置（必填）
# TCP 连接方式(默认)
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=examhub
# Socket 连接方式(本地 root 免密时使用,优先级高于 TCP)
# DB_SOCKET=/run/mysqld/mysqld.sock

# JWT 配置（必填，否则服务拒绝启动）
# 必须为 >= 16 字符的强随机字符串，推荐使用：openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

# 站点 URL（生产环境必填，用于 CORS 白名单；未设置时将拒绝所有跨域请求）
# 示例：https://your-domain.com
SITE_URL=

# 敏感配置加密密钥（可选，强烈推荐生产环境设置）
# 用于加密数据库中存储的 AI API Key 等敏感配置（AES-256-GCM）
# 未设置时将从 JWT_SECRET 派生密钥（与 JWT 密钥耦合，密钥变更会导致解密失败）
# 推荐使用独立密钥：openssl rand -hex 32
# SETTINGS_ENCRYPTION_KEY=

# 管理员默认账号（仅 npm run migrate 时使用，/setup 向导会单独创建）
# 不设置则 migrate 时不会创建默认管理员，需通过 /setup 向导创建
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
